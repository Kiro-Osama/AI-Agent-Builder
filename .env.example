# Copy to .env and adjust. Do not commit .env with real secrets.

# --- PostgreSQL (db service) ---
POSTGRES_USER=agentbuilder
POSTGRES_PASSWORD=YOUR_PASSWORD
POSTGRES_DB=agentbuilder_db

# --- Async API (SQLAlchemy + asyncpg) ---
DATABASE_URL=postgresql+asyncpg://agentbuilder:YOUR_PASSWORD@db:5432/agentbuilder_db

# --- Alembic / Celery / scripts (sync psycopg2) ---
ALEMBIC_DATABASE_URL=postgresql://agentbuilder:YOUR_PASSWORD@db:5432/agentbuilder_db

# --- Redis (Celery broker) ---
REDIS_URL=redis://redis:6379/0

# --- OpenRouter ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_CHAT_MODEL=google/gemma-4-26b-a4b-it:free

# --- Embeddings (MCP catalog) ---
GEMINI_API_KEY=

# --- App ---
APP_ENV=development
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- MCP / agent runtime ---
WORKSPACE_PATH=/workspace
AGENT_MAX_ITERATIONS=15
MCP_TIMEOUT=30
SESSION_TTL_MINUTES=60
