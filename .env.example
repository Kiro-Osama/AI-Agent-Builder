# ============================================
# Agent Builder System V5 — Environment
# ============================================
# Copy to .env and fill in your values.
# NEVER commit .env with real secrets.

# --- PostgreSQL (db service) ---
POSTGRES_USER=agentbuilder
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=agentbuilder_db

# --- Async API (SQLAlchemy + asyncpg) ---
DATABASE_URL=postgresql+asyncpg://agentbuilder:CHANGE_ME@db:5432/agentbuilder_db

# --- Alembic / Celery / worker (sync psycopg2) ---
ALEMBIC_DATABASE_URL=postgresql://agentbuilder:CHANGE_ME@db:5432/agentbuilder_db

# --- Redis (Celery broker + result backend) ---
REDIS_URL=redis://redis:6379/0

# --- OpenRouter (LLM gateway) ---
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_API_KEY_BACKUP=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_CHAT_MODEL=google/gemma-4-26b-a4b-it:free

# --- Local Ollama (optional alternative to OpenRouter) ---
# Use either a per-model prefix `ollama:qwen3.5:4b-q4_K_M` in DEFAULT_CHAT_MODEL / agent model,
# or force all LLM calls to Ollama:
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=qwen3.5:4b-q4_K_M
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# From Docker Desktop (API/worker → host Ollama): OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_API_KEY=   # only if you put a reverse proxy with auth in front of Ollama
# The web UI can send llm_provider per build/chat (openrouter | ollama | ollama_remote).

# --- Ollama on another host (ngrok, VPS) — OpenAI-compatible /v1 (like LangChain ChatOpenAI) ---
# LLM_PROVIDER=ollama_remote
# OLLAMA_REMOTE_BASE_URL=https://xxxx.ngrok-free.app
# OLLAMA_REMOTE_API_KEY=ollama
# OLLAMA_REMOTE_MODEL=qwen3.5:4b
# OLLAMA_REMOTE_NGROK_SKIP=1

# Model tier overrides (optional)
# OPENROUTER_MODEL_SIMPLE=meta-llama/llama-3.3-70b-instruct:free
# OPENROUTER_MODEL_MEDIUM=google/gemma-4-26b-a4b-it:free
# OPENROUTER_MODEL_COMPLEX=qwen/qwen3-next-80b-a3b-instruct:free
# OPENROUTER_MODEL_CREATIVE=google/gemma-4-31b-it:free

# --- Embeddings (Google Gemini) ---
GEMINI_API_KEY=

# --- Google Gemini (DeepAgent Runtime LLM — primary model) ---
GOOGLE_API_KEY=
DEEPAGENT_MODEL=gemini-3.1-flash-lite-preview
DEEPAGENT_TEMPERATURE=0.2

# --- LangSmith (optional — traces LangGraph builds + LangChain / DeepAgent runs) ---
# Create an API key at https://smith.langchain.com — never commit real keys.
# LANGSMITH_API_KEY=
# Default project name in the LangSmith UI (overridable):
# LANGCHAIN_PROJECT=agent_builder
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# Tracing is enabled automatically when LANGSMITH_API_KEY is set (API/worker sync env on boot).

# --- App settings ---
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- MCP / agent runtime ---
WORKSPACE_PATH=/workspace
AGENT_MAX_ITERATIONS=15
MCP_TIMEOUT=30
SESSION_TTL_MINUTES=60
