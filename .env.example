# ============================================
# Agent Builder System V5 — Environment
# ============================================
# Copy to .env and fill in your values.
# NEVER commit .env with real secrets.

# --- PostgreSQL (db service) ---
POSTGRES_USER=agentbuilder
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=agentbuilder_db

# --- Async API (SQLAlchemy + asyncpg) ---
DATABASE_URL=postgresql+asyncpg://agentbuilder:CHANGE_ME@db:5432/agentbuilder_db

# --- Alembic / Celery / worker (sync psycopg2) ---
ALEMBIC_DATABASE_URL=postgresql://agentbuilder:CHANGE_ME@db:5432/agentbuilder_db

# --- Redis (Celery broker + result backend) ---
REDIS_URL=redis://redis:6379/0

# --- OpenRouter (LLM gateway) ---
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_API_KEY_BACKUP=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_CHAT_MODEL=google/gemma-4-26b-a4b-it:free

# Model tier overrides (optional)
# OPENROUTER_MODEL_SIMPLE=meta-llama/llama-3.3-70b-instruct:free
# OPENROUTER_MODEL_MEDIUM=google/gemma-4-26b-a4b-it:free
# OPENROUTER_MODEL_COMPLEX=qwen/qwen3-next-80b-a3b-instruct:free
# OPENROUTER_MODEL_CREATIVE=google/gemma-4-31b-it:free

# --- Embeddings (Google Gemini) ---
GEMINI_API_KEY=

# --- App settings ---
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- MCP / agent runtime ---
WORKSPACE_PATH=/workspace
AGENT_MAX_ITERATIONS=15
MCP_TIMEOUT=30
SESSION_TTL_MINUTES=60
